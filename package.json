{
  "name": "speedload",
  "version": "1.0.0",
  "description": "SpeedLoad - Download Accelerator. Free forever.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never",
    "build-mac": "electron-builder --mac --publish never",
    "build-linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.speedload.app",
    "productName": "SpeedLoad",
    "copyright": "Free Forever — Donate if you want.",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "fs-extra": "^11.2.0"
  }
}
